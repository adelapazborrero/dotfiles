set ideajoin
set clipboard+=unnamed

nmap wl :action NextSplitter<CR>
nmap wh :action PrevSplitter<CR>

nmap ;f :action GotoFile<CR>
nmap ;r :action FindInPath<CR>

nmap vs :action SplitVertically<CR>
nmap ;g :action Vcs.ShowDiffChangedLines<CR>
nmap gr :action Vcs.RollbackChangedLines<CR>
nmap gt :action Vcs.ShowDiffWithLocal.Before<CR>

nmap [g :action GotoPreviousError<CR>
nmap ]g :action GotoNextError<CR>

nmap gz :action Vcs.Log.ShowDiffPreview<CR>
